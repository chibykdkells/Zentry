# ================================================================
# ZENDOCX — ENVIRONMENT VARIABLES TEMPLATE
# Copy this to .env and fill in real values. NEVER commit .env
# ================================================================

# ── App ──────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
API_URL=http://localhost:4000
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000
PLATFORM_DOMAIN=zendocx.net
NEXT_PUBLIC_DEV_TENANT_SLUG=testbiz

# ── Database ─────────────────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL=postgresql://postgres:password@localhost:5432/zendocx_db

# ── Redis ────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT (use minimum 64-character random strings) ───────────────
JWT_ACCESS_SECRET=REPLACE_WITH_64_CHAR_RANDOM_STRING_FOR_ACCESS_TOKEN
JWT_REFRESH_SECRET=REPLACE_WITH_64_CHAR_RANDOM_STRING_FOR_REFRESH_TOKEN
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Active Providers (change value to swap provider — no code change) ──
ACTIVE_PAYMENT_PROVIDER=PAYSTACK
ACTIVE_VTU_PROVIDER=PROVIDER_ONE
ACTIVE_SMS_PROVIDER=TERMII
ACTIVE_EMAIL_PROVIDER=RESEND
ACTIVE_STORAGE_PROVIDER=CLOUDINARY

# ── Payment: FintavaPay (Primary) ────────────────────────────────
FINTAVAPAY_BASE_URL=
FINTAVAPAY_PUBLIC_KEY=
FINTAVAPAY_SECRET_KEY=
FINTAVAPAY_WEBHOOK_SECRET=

# ── Payment: Paystack (Backup #1) ────────────────────────────────
PAYSTACK_SECRET_KEY=
PAYSTACK_WEBHOOK_SECRET=

# ── Payment: Flutterwave (Backup #2) ─────────────────────────────
FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_WEBHOOK_SECRET=

# ── VTU Provider ─────────────────────────────────────────────────
VTU_PROVIDER_ONE_BASE_URL=
VTU_PROVIDER_ONE_API_KEY=

# ── SMS: Termii ──────────────────────────────────────────────────
TERMII_API_KEY=
TERMII_SENDER_ID=ZenDocx

# ── Email: Resend ────────────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@zendocx.net
RESEND_FROM_NAME=ZenDocx

# ── Web Push (VAPID) ─────────────────────────────────────────────
# Generate a P-256 VAPID keypair and place the base64url values here.
WEB_PUSH_VAPID_PUBLIC_KEY=
WEB_PUSH_VAPID_PRIVATE_KEY=
WEB_PUSH_VAPID_SUBJECT=mailto:support@zendocx.net

# ── Storage: Cloudinary ──────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Security ─────────────────────────────────────────────────────
BCRYPT_ROUNDS=12
PIN_BCRYPT_ROUNDS=10
OTP_EXPIRY_MINUTES=10
PASSWORD_RESET_EXPIRY_HOURS=1
DISPUTE_WINDOW_HOURS=2
MAX_PIN_ATTEMPTS=5
PIN_LOCKOUT_MINUTES=15
MAX_OTP_ATTEMPTS=5

# ── Platform Config ──────────────────────────────────────────────
PLATFORM_MIN_WITHDRAWAL_KOBO=100000

# ── Monitoring: Sentry ───────────────────────────────────────────
# Create a project at https://sentry.io and paste the DSN values here.
# Leave blank to disable Sentry (safe for local development).
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
