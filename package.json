{
  "name": "zentry",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "verify:phase1": "pnpm lint && pnpm typecheck && pnpm test && pnpm build",
    "verify:phase1:runtime": "node ./scripts/verify-phase1-runtime.mjs",
    "infra:up": "docker compose up -d",
    "infra:down": "docker compose down",
    "infra:logs": "docker compose logs -f postgres redis",
    "db:migrate": "pnpm --filter @zentry/api db:migrate",
    "db:seed": "pnpm --filter @zentry/api db:seed",
    "db:studio": "pnpm --filter @zentry/api db:studio",
    "db:generate": "pnpm --filter @zentry/api db:generate",
    "db:reset": "pnpm --filter @zentry/api db:reset"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "prettier": "^3.4.2",
    "eslint": "^9.18.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.33.0"
}
