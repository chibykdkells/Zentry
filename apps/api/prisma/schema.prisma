generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Enums ────────────────────────────────────────────────────────

enum UserRole {
  INDIVIDUAL
  CBT_CENTER
  CBT_STAFF
  TENANT_ADMIN
  SUPER_ADMIN
}

enum OrderStatus {
  PENDING
  ASSIGNED
  IN_PROGRESS
  COMPLETED
  DISPUTED
  RESOLVED
  CANCELLED
  REFUNDED
}

enum TransactionType {
  WALLET_FUNDING
  SERVICE_PURCHASE
  ESCROW_LOCK
  ESCROW_RELEASE
  PLATFORM_COMMISSION
  TENANT_COMMISSION
  CBT_COMMISSION
  WITHDRAWAL
  REFUND
  PENALTY
}

enum TransactionStatus {
  PENDING
  SUCCESS
  FAILED
  REVERSED
}

enum FulfillmentType {
  MANUAL
  AUTOMATED
}

enum ServiceDeliveryMode {
  CBT_MANUAL
  API_AUTOMATED
  PIN_STOCK
}

enum CbtApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED_FOR_REQUESTER
  RESOLVED_FOR_CBT
  REDO_REQUESTED
}

enum WithdrawalStatus {
  PENDING
  APPROVED
  PROCESSING
  COMPLETED
  REJECTED
}

enum NotificationType {
  ORDER_PLACED
  ORDER_ASSIGNED
  ORDER_COMPLETED
  DISPUTE_RAISED
  DISPUTE_RESOLVED
  WITHDRAWAL_APPROVED
  WITHDRAWAL_REJECTED
  WALLET_FUNDED
  CBT_APPROVED
  CBT_REJECTED
  JOB_AVAILABLE
}

enum PaymentGateway {
  FINTAVAPAY
  PAYSTACK
  FLUTTERWAVE
}

enum OtpType {
  EMAIL_VERIFY
  PHONE_VERIFY
  PASSWORD_RESET
  LOGIN_2FA
}

enum ProviderRolloutMode {
  AUTO
  MOCK
  LIVE
}

enum ProviderConfigScope {
  PLATFORM
  TENANT
}

// ── Models ───────────────────────────────────────────────────────

model Tenant {
  id                   String    @id @default(uuid())
  name                 String
  slug                 String    @unique
  customDomain         String?   @unique
  customDomainVerified Boolean   @default(false)
  logoUrl              String?
  primaryColor         String    @default("#0D1B3E")
  accentColor          String    @default("#F5A623")
  textColor            String    @default("#10203C")
  buttonColor          String    @default("#0D1B3E")
  fontStyle            String    @default("modern")
  tenantMarginRate     Int       @default(0)
  usesCustomServiceSelection Boolean @default(false)
  isActive             Boolean   @default(true)
  createdById          String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  users              User[]
  orders             Order[]
  serviceCategories  ServiceCategoryModel[]
  services           Service[]
  serviceSelections  TenantServiceSelection[]
  withdrawalRequests WithdrawalRequest[]
  auditLogs          AuditLog[]
  cbtProfiles        CbtProfile[]
  tenantAdminAccesses TenantAdminAccess[]

  @@map("tenants")
}

model User {
  id               String    @id @default(uuid())
  tenantId         String?
  tenant           Tenant?   @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  firstName        String
  lastName         String
  email            String
  phone            String
  passwordHash     String
  walletPin        String?
  role             UserRole
  isEmailVerified  Boolean   @default(false)
  isPhoneVerified  Boolean   @default(false)
  isActive         Boolean   @default(true)
  lastLoginAt      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  wallet           Wallet?
  cbtProfile       CbtProfile?
  ordersPlaced     Order[]            @relation("OrderRequester")
  ordersAssigned   Order[]            @relation("OrderCbt")
  transactions     Transaction[]
  disputesRaised   Dispute[]          @relation("DisputeRaiser")
  disputesResolved Dispute[]          @relation("DisputeResolver")
  withdrawals      WithdrawalRequest[]
  notifications    Notification[]
  pushSubscriptions PushSubscription[]
  auditLogs        AuditLog[]
  otpTokens        OtpToken[]
  passwordResets   PasswordReset[]
  tenantAdminAccesses TenantAdminAccess[]
  cbtStaffProfile  CbtStaffMembership? @relation("CbtStaff_Member")
  cbtStaffMembers  CbtStaffMembership[] @relation("CbtCenter_Staff")

  @@index([email])
  @@index([phone])
  @@index([role])
  @@index([isActive])
  @@index([tenantId])
  @@unique([tenantId, email])
  @@unique([tenantId, phone])
}

model Wallet {
  id               String   @id @default(uuid())
  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  availableBalance BigInt   @default(0)
  escrowBalance    BigInt   @default(0)
  totalEarned      BigInt   @default(0)
  totalWithdrawn   BigInt   @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  transactions Transaction[]

  @@index([userId])
}

model Transaction {
  id            String            @id @default(uuid())
  tenantId      String?
  walletId      String
  wallet        Wallet            @relation(fields: [walletId], references: [id])
  userId        String
  user          User              @relation(fields: [userId], references: [id])
  type          TransactionType
  status        TransactionStatus @default(PENDING)
  amount        BigInt
  balanceBefore BigInt
  balanceAfter  BigInt
  reference     String            @unique
  gatewayRef    String?
  gateway       PaymentGateway?
  description   String
  metadata      Json?
  orderId       String?
  order         Order?            @relation(fields: [orderId], references: [id])
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([walletId])
  @@index([userId])
  @@index([reference])
  @@index([status])
  @@index([type])
  @@index([createdAt])
  @@index([tenantId])
}

model CbtProfile {
  id              String            @id @default(uuid())
  tenantId        String?
  tenant          Tenant?           @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  userId          String            @unique
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  centerName      String
  licenseNumber   String            @unique
  supportingDocUrl String?
  address         String
  state           String
  lga             String
  approvalStatus  CbtApprovalStatus @default(PENDING)
  approvedAt      DateTime?
  approvedById    String?
  rejectionReason String?
  isOnline        Boolean           @default(false)
  lastSeenAt      DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([approvalStatus])
  @@index([licenseNumber])
  @@index([tenantId])
}

model ServiceCategoryModel {
  id          String    @id @default(uuid())
  tenantId    String?
  tenant      Tenant?   @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  name        String
  slug        String
  description String?
  iconUrl     String?
  isActive    Boolean   @default(true)
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  services    Service[]

  @@unique([slug, tenantId])
  @@unique([name, tenantId])
  @@index([tenantId])
  @@map("service_categories")
}

model Service {
  id                  String               @id @default(uuid())
  tenantId            String?
  tenant              Tenant?              @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  categoryId          String
  category            ServiceCategoryModel @relation(fields: [categoryId], references: [id])
  name                String
  slug                String
  description         String?
  requiredDocuments   Json                 @default("[]")
  requiredFields      Json                 @default("[]")
  deliveryMode        ServiceDeliveryMode
  fulfillmentType     FulfillmentType
  providerCost        BigInt               @default(0)
  platformFee         BigInt
  tenantFee           BigInt               @default(0)
  totalPrice          BigInt
  cbtCommission       BigInt               @default(0)
  providerKey         String?
  providerServiceCode String?
  isActive            Boolean              @default(true)
  sortOrder           Int                  @default(0)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  orders              Order[]

  @@unique([slug, tenantId])
  @@index([categoryId])
  @@index([tenantId])
  @@index([deliveryMode])
  @@index([fulfillmentType])
  @@index([isActive])
}

model PlatformProviderConfig {
  id                        String              @id @default(uuid())
  providerType              String
  providerKey               String
  scopeType                 ProviderConfigScope @default(PLATFORM)
  scopeKey                  String              @default("platform")
  displayName               String
  isEnabled                 Boolean             @default(true)
  rolloutMode               ProviderRolloutMode @default(AUTO)
  baseUrl                   String?
  apiKeyEncrypted           String?
  apiKeyLast4               String?
  apiKeyHeader              String?
  apiKeyPrefix              String?
  healthPath                String?
  airtimePath               String?
  dataPurchasePath          String?
  dataPlansPath             String?
  cablePlansPath            String?
  cableVerifyPath           String?
  cablePurchasePath         String?
  electricityVerifyPath     String?
  electricityPurchasePath   String?
  notes                     String?
  lastValidatedAt           DateTime?
  lastValidationStatus      String?
  lastValidationMessage     String?
  createdAt                 DateTime            @default(now())
  updatedAt                 DateTime            @updatedAt
  validationEvents          ProviderValidationEvent[]

  @@unique([providerType, providerKey, scopeType, scopeKey], map: "ppc_type_key_scope_unique")
  @@index([providerType, providerKey, scopeType, scopeKey], map: "ppc_type_key_scope_idx")
  @@map("platform_provider_configs")
}

model ProviderValidationEvent {
  id                  String               @id @default(uuid())
  providerConfigId    String?
  providerConfig      PlatformProviderConfig? @relation(fields: [providerConfigId], references: [id], onDelete: Cascade)
  providerType        String
  providerKey         String
  scopeType           ProviderConfigScope  @default(PLATFORM)
  scopeKey            String               @default("platform")
  rolloutMode         ProviderRolloutMode
  effectiveMode       String
  probeStatus         String
  probeMessage        String
  missingConfig       Json?
  endpointBaseUrl     String?
  createdAt           DateTime             @default(now())

  @@index([providerType, providerKey, scopeType, scopeKey, createdAt], map: "pve_lookup_created_idx")
  @@map("provider_validation_events")
}

model Order {
  id                     String      @id @default(uuid())
  tenantId               String?
  tenant                 Tenant?     @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  orderNumber            String      @unique
  requesterId            String
  requester              User        @relation("OrderRequester", fields: [requesterId], references: [id])
  serviceId              String
  service                Service     @relation(fields: [serviceId], references: [id])
  status                 OrderStatus @default(PENDING)
  deliveryMode           ServiceDeliveryMode
  fulfillmentType        FulfillmentType
  submittedData          Json
  requesterDocUrls       Json        @default("[]")
  resultFileUrl          String?
  resultUploadedAt       DateTime?
  totalAmount            BigInt
  platformFee            BigInt
  tenantFee              BigInt      @default(0)
  cbtCommission          BigInt
  escrowReleasedAt       DateTime?
  disputeWindowExpiresAt DateTime?
  assignedCbtId          String?
  assignedCbt            User?       @relation("OrderCbt", fields: [assignedCbtId], references: [id])
  assignedAt             DateTime?
  completedAt            DateTime?
  providerReference      String?
  providerResponse       Json?
  cbtNotes               String?
  adminNotes             String?
  createdAt              DateTime    @default(now())
  updatedAt              DateTime    @updatedAt

  transactions  Transaction[]
  dispute       Dispute?
  notifications Notification[]

  @@index([tenantId])
  @@index([requesterId])
  @@index([assignedCbtId])
  @@index([status])
  @@index([deliveryMode])
  @@index([orderNumber])
  @@index([createdAt])
}

model Dispute {
  id              String        @id @default(uuid())
  tenantId        String?
  orderId         String        @unique
  order           Order         @relation(fields: [orderId], references: [id])
  raisedById      String
  raisedBy        User          @relation("DisputeRaiser", fields: [raisedById], references: [id])
  reason          String        @db.Text
  evidenceUrls    Json          @default("[]")
  status          DisputeStatus @default(OPEN)
  resolvedById    String?
  resolvedBy      User?         @relation("DisputeResolver", fields: [resolvedById], references: [id])
  resolutionNote  String?       @db.Text
  resolvedAt      DateTime?
  redoDeadline    DateTime?
  redoCompletedAt DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([tenantId])
  @@index([status])
  @@index([raisedById])
}

model WithdrawalRequest {
  id            String           @id @default(uuid())
  tenantId      String?
  tenant        Tenant?          @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  userId        String
  user          User             @relation(fields: [userId], references: [id])
  amount        BigInt
  bankName      String
  bankCode      String
  accountNumber String
  accountName   String
  status        WithdrawalStatus @default(PENDING)
  processedById String?
  processorNote String?
  gatewayRef    String?
  processedAt   DateTime?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([tenantId])
  @@index([userId])
  @@index([status])
}

model Notification {
  id        String           @id @default(uuid())
  tenantId  String?
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  message   String           @db.Text
  isRead    Boolean          @default(false)
  readAt    DateTime?
  metadata  Json?
  orderId   String?
  order     Order?           @relation(fields: [orderId], references: [id])
  createdAt DateTime         @default(now())

  @@index([tenantId])
  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
}

model PushSubscription {
  id         String   @id @default(uuid())
  tenantId    String?
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint    String   @unique
  p256dh      String
  auth        String
  userAgent   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  lastUsedAt  DateTime?

  @@index([tenantId])
  @@index([userId])
  @@map("push_subscriptions")
}

model TenantAdminAccess {
  id                    String   @id @default(uuid())
  tenantId              String
  tenant                Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId                String
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdById           String?
  email                 String
  encryptedTempPassword String
  isActive              Boolean  @default(true)
  lastResetAt           DateTime?
  dismissedAt           DateTime?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([tenantId, isActive])
  @@index([userId, isActive])
  @@index([createdAt])
}

model CbtStaffMembership {
  id        String   @id @default(uuid())
  cbtId     String
  cbt       User     @relation("CbtCenter_Staff", fields: [cbtId], references: [id], onDelete: Cascade)
  staffId   String   @unique
  staff     User     @relation("CbtStaff_Member", fields: [staffId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([cbtId])
  @@map("cbt_staff_memberships")
}

model TenantServiceSelection {
  id          String   @id @default(uuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  serviceSlug String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([tenantId, serviceSlug])
  @@index([tenantId])
  @@index([serviceSlug])
  @@map("tenant_service_selections")
}

model OtpToken {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String
  type      OtpType
  expiresAt DateTime
  usedAt    DateTime?
  attempts  Int      @default(0)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([type])
}

model PasswordReset {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String
  expiresAt DateTime
  usedAt    DateTime?
  ipAddress String?
  createdAt DateTime  @default(now())

  @@index([userId])
}

model AuditLog {
  id        String   @id @default(uuid())
  tenantId  String?
  tenant    Tenant?  @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action    String
  entity    String
  entityId  String?
  oldValues Json?
  newValues Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([tenantId])
  @@index([userId])
  @@index([action])
  @@index([entity])
  @@index([createdAt])
}

model SystemConfig {
  id          String   @id @default(uuid())
  key         String   @unique
  value       String   @db.Text
  description String?
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
